generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                         String                @id @default(cuid())
  name                       String
  email                      String                @unique
  phone                      String?
  passwordHash               String
  role                       String                @default("CUSTOMER")
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt
  addresses                  Address[]
  orders                     Order[]
  wishlist                   WishlistItem[]
  reviews                    Review[]
  internalNotes              InternalNote[]
  notesAuthored              InternalNote[]        @relation("InternalNoteAuthor")
  inventoryAdjustments       InventoryAdjustment[]
  analyticsEvents            AnalyticsEvent[]
  emailQueue                 EmailQueue[]
  emailLogs                  EmailLog[]
  auroraEvaluationsRequested AuroraEvaluation[]    @relation("AuroraEvaluationRequestedBy")
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String   @default("Home")
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  country   String   @default("India")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isDefault])
}

model Category {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  description     String
  imageUrl        String?
  shippingFee     Int       @default(0)
  isActive        Boolean   @default(true)
  isFeatured      Boolean   @default(false)
  metaTitle       String?
  metaDescription String?
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  products        Product[]
}

model Product {
  id                   String                @id @default(cuid())
  categoryId           String
  name                 String
  slug                 String                @unique
  description          String
  story                String
  price                Int
  compareAtPrice       Int?
  imageUrl             String
  inventory            Int                   @default(0)
  lowStockThreshold    Int                   @default(3)
  adminStatus          String                @default("PUBLISHED")
  archivedAt           DateTime?
  isFeatured           Boolean               @default(false)
  isActive             Boolean               @default(true)
  handmadeDaysMin      Int                   @default(5)
  handmadeDaysMax      Int                   @default(12)
  customizationFields  String                @default("[]")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  category             Category              @relation(fields: [categoryId], references: [id])
  orderItems           OrderItem[]
  wishlistItems        WishlistItem[]
  reviews              Review[]
  inventoryAdjustments InventoryAdjustment[]
  analyticsEvents      AnalyticsEvent[]
  auroraEvaluations    AuroraEvaluation[]
}

model AuroraEvaluation {
  id                            String   @id @default(cuid())
  requestKey                    String   @unique
  requestIdentityJson           String
  requestIdentityFingerprint    String
  operationType                 String
  requestMode                   String
  trigger                       String
  requestedById                 String?
  requestedByIdAtExecution      String
  batchRequestKey               String?
  batchIdentityFingerprint      String?
  batchItemIndex                Int?
  batchSize                     Int?
  productId                     String?
  productIdAtExecution          String
  productSlug                   String
  productName                   String
  bindingId                     String
  bindingFingerprint            String
  bindingManifestFingerprint    String
  projectId                     String
  bundleFingerprint             String
  bundleSha256                  String
  sdkVersion                    String
  runtimeContractsJson          String
  productDnaArtifactId          String
  productDnaProductId           String
  productDnaFingerprint         String?
  ruleSetArtifactId             String
  ruleSetDomainId               String
  ruleSetFingerprint            String?
  applicationContextFingerprint String
  auroraInputFingerprint        String?
  auroraOutputFingerprint       String?
  inputSnapshotJson             String
  resultJson                    String?
  resultSha256                  String?
  resultBytes                   Int?
  status                        String
  failureStage                  String?
  issueCodesJson                String   @default("[]")
  durationMs                    Int
  createdAt                     DateTime @default(now())
  product                       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  requestedBy                   User?    @relation("AuroraEvaluationRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
  @@index([productIdAtExecution, createdAt])
  @@index([applicationContextFingerprint, status, createdAt])
  @@index([bindingId, createdAt])
  @@index([batchRequestKey, batchItemIndex])
  @@index([requestedById, createdAt])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique
  description String
  type        String    @default("PERCENT")
  value       Int
  minSubtotal Int       @default(0)
  usageLimit  Int?
  isActive    Boolean   @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Order {
  id                   String           @id @default(cuid())
  orderNumber          String           @unique
  userId               String
  status               String           @default("PLACED")
  paymentStatus        String           @default("PENDING")
  currency             String           @default("INR")
  subtotal             Int
  shippingFee          Int
  shippingCharge       Int              @default(0)
  discount             Int              @default(0)
  total                Int
  customNotes          String?
  deliveryName         String
  deliveryPhone        String
  deliveryLine1        String
  deliveryLine2        String?
  deliveryCity         String
  deliveryState        String
  deliveryPincode      String
  razorpayOrderId      String?
  razorpayPaymentId    String?
  razorpaySignature    String?
  shiprocketOrderId    String?
  shiprocketShipmentId String?
  awbCode              String?
  courierCompanyId     Int?
  courierName          String?
  courierTrackingId    String?
  courierTrackingUrl   String?
  pickupPincode        String?
  estimatedDelivery    DateTime?
  shipmentStatus       String?
  trackingUrl          String?
  trackingEvents       String           @default("[]")
  pickupGenerated      Boolean          @default(false)
  shipmentError        String?
  shippedAt            DateTime?
  deliveredAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  user                 User             @relation(fields: [userId], references: [id])
  items                OrderItem[]
  timeline             OrderTimeline[]
  internalNotes        InternalNote[]
  emailQueue           EmailQueue[]
  emailLogs            EmailLog[]
  reviews              Review[]
  analyticsEvents      AnalyticsEvent[]

  @@index([shiprocketShipmentId])
  @@index([awbCode])
  @@index([shipmentStatus])
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String?
  productName     String
  productImageUrl String
  unitPrice       Int
  quantity        Int
  customization   String   @default("{}")
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  reviews         Review[]
}

model OrderTimeline {
  id                String   @id @default(cuid())
  orderId           String
  status            String
  title             String
  note              String
  actor             String   @default("SYSTEM")
  isCustomerVisible Boolean  @default(true)
  createdAt         DateTime @default(now())
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String
  ctaLabel  String
  ctaHref   String
  imageUrl  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailQueue {
  id               String          @id @default(cuid())
  orderId          String?
  userId           String?
  contactEnquiryId String?
  event            String
  recipient        String
  subject          String
  template         String
  payload          String
  status           String          @default("PENDING")
  attempts         Int             @default(0)
  maxAttempts      Int             @default(3)
  lastError        String?
  scheduledAt      DateTime        @default(now())
  sentAt           DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  logs             EmailLog[]
  order            Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  user             User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  contactEnquiry   ContactEnquiry? @relation(fields: [contactEnquiryId], references: [id], onDelete: SetNull)

  @@index([status, scheduledAt])
  @@index([event])
  @@index([recipient])
  @@index([orderId])
  @@index([userId])
  @@index([contactEnquiryId])
}

model EmailLog {
  id               String      @id @default(cuid())
  queueId          String?
  orderId          String?
  userId           String?
  event            String
  recipient        String
  subject          String
  status           String
  providerResponse String?     @map("smtpResponse")
  error            String?
  createdAt        DateTime    @default(now())
  queue            EmailQueue? @relation(fields: [queueId], references: [id], onDelete: SetNull)
  order            Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  user             User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([queueId])
  @@index([orderId])
  @@index([userId])
  @@index([event])
  @@index([status])
  @@index([createdAt])
}

model Review {
  id          String     @id @default(cuid())
  orderId     String?
  orderItemId String?
  productId   String
  userId      String
  rating      Int
  title       String?
  body        String
  status      String     @default("PENDING")
  isFeatured  Boolean    @default(false)
  reply       String?
  repliedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  order       Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orderItemId, userId])
  @@index([productId, status])
  @@index([userId])
  @@index([orderId])
  @@index([status, createdAt])
}

model ContactEnquiry {
  id               String         @id @default(cuid())
  name             String
  email            String?
  phone            String
  occasion         String
  productType      String
  budget           String
  message          String
  referenceFileUrl String?
  status           String         @default("NEW")
  source           String         @default("CONTACT_FORM")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  internalNotes    InternalNote[]
  emailQueue       EmailQueue[]

  @@index([status, createdAt])
  @@index([email])
  @@index([phone])
}

model InternalNote {
  id               String          @id @default(cuid())
  targetType       String
  targetId         String
  orderId          String?
  userId           String?
  contactEnquiryId String?
  reviewId         String?
  authorId         String?
  content          String
  createdAt        DateTime        @default(now())
  order            Order?          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user             User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactEnquiry   ContactEnquiry? @relation(fields: [contactEnquiryId], references: [id], onDelete: Cascade)
  author           User?           @relation("InternalNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@index([orderId])
  @@index([userId])
  @@index([contactEnquiryId])
  @@index([reviewId])
}

model Notification {
  id         String    @id @default(cuid())
  type       String
  title      String
  body       String
  href       String?
  severity   String    @default("INFO")
  status     String    @default("UNREAD")
  sourceType String?
  sourceId   String?
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  @@unique([type, sourceType, sourceId])
  @@index([status, createdAt])
  @@index([type])
}

model InventoryAdjustment {
  id        String   @id @default(cuid())
  productId String
  delta     Int
  reason    String
  note      String?
  actorId   String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
}

model StoreSetting {
  key       String   @id
  group     String
  label     String
  value     String
  valueType String   @default("text")
  updatedAt DateTime @updatedAt

  @@index([group])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  event     String
  sessionId String?
  userId    String?
  productId String?
  orderId   String?
  metadata  String   @default("{}")
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([event, createdAt])
  @@index([sessionId])
  @@index([userId])
  @@index([productId])
  @@index([orderId])
}
